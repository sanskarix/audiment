rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ───────────────────────────────

    // Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Get the current user's Firestore document
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Role checks
    function isAdmin() {
      return isAuth() && getUserData().role == 'admin';
    }

    function isManager() {
      return isAuth() && getUserData().role == 'manager';
    }

    function isAuditor() {
      return isAuth() && getUserData().role == 'auditor';
    }

    // Branch access checks
    function managerManagesBranch(locationId) {
      return isManager() && locationId in getUserData().assignedLocations;
    }

    function auditorAssignedToBranch(locationId) {
      return isAuditor() && locationId in getUserData().assignedLocations;
    }

    function adminOrManagesThisBranch(locationId) {
      return isAdmin() || managerManagesBranch(locationId);
    }

    // ─── USERS COLLECTION ───────────────────────────────
    // Only admin can list/create/delete users
    // Users can read and update their own profile only

    match /users/{userId} {
      allow read: if isAuth() && 
        (request.auth.uid == userId || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin() || 
        request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // ─── LOCATIONS COLLECTION ────────────────────────────
    // Admin: full access
    // Manager: read branches assigned to them only
    // Auditor: read branches assigned to them only

    match /locations/{locationId} {
      allow read: if isAdmin() || 
        managerManagesBranch(locationId) || 
        auditorAssignedToBranch(locationId);
      allow create, update, delete: if isAdmin();
    }

    // ─── AUDIT TEMPLATES COLLECTION ─────────────────────
    // Admin: full access
    // Manager: read templates for their branches
    // Auditor: read active templates for their branches

    match /auditTemplates/{templateId} {
      allow read: if isAdmin() || 
        (isManager() && resource.data.locationIds.hasAny(getUserData().assignedLocations)) ||
        (isAuditor() && resource.data.locationIds.hasAny(getUserData().assignedLocations) && 
         resource.data.status == 'active');
      allow create, update, delete: if isAdmin();
    }

    // ─── AUDITS COLLECTION ───────────────────────────────
    // Admin: full access
    // Manager: read/create/update for their branches only
    // Auditor: read assignments assigned to them only

    match /audits/{auditId} {
      allow read: if isAdmin() || 
        managerManagesBranch(resource.data.locationId) ||
        (isAuditor() && resource.data.assignedAuditorId == request.auth.uid);
      allow create, update: if isAdmin() || 
        managerManagesBranch(resource.data.locationId);
      allow delete: if isAdmin();
    }

    // ─── AUDIT RESPONSES COLLECTION ─────────────────────
    // Admin: full access
    // Manager: read submissions for their branches only
    // Auditor: read/create/update their own submissions only

    match /auditResponses/{responseId} {
      allow read: if isAdmin() || 
        managerManagesBranch(resource.data.locationId) ||
        (isAuditor() && resource.data.auditorId == request.auth.uid);
      allow create: if isAuditor() && 
        auditorAssignedToBranch(request.resource.data.locationId) &&
        request.resource.data.auditorId == request.auth.uid;
      allow update: if isAdmin() || 
        (isAuditor() && resource.data.auditorId == request.auth.uid &&
         resource.data.submittedAt == null);
      allow delete: if isAdmin();
    }

    // ─── CORRECTIVE ACTIONS COLLECTION ──────────────────
    // Admin: full access
    // Manager: read/update corrective actions for their branches
    // Auditor: read corrective actions they created (via submission)

    match /correctiveActions/{actionId} {
      allow read: if isAdmin() || 
        managerManagesBranch(resource.data.locationId) ||
        (isAuditor() && resource.data.locationId in getUserData().assignedLocations);
      allow create: if isAdmin() || 
        managerManagesBranch(request.resource.data.locationId);
      allow update: if isAdmin() || 
        managerManagesBranch(resource.data.locationId);
      allow delete: if isAdmin();
    }

    // ─── FLASHMOB AUDITS COLLECTION ─────────────────────
    // CRITICAL: Managers must NEVER see flashmob data
    // Admin: full access
    // Auditor: create only (cannot read back their own)

    match /flashmobAudits/{flashmobId} {
      allow read: if isAdmin();
      allow create: if isAuditor() && 
        auditorAssignedToBranch(request.resource.data.locationId) &&
        request.resource.data.auditorId == request.auth.uid &&
        request.resource.data.isVisibleToManager == false;
      allow update, delete: if isAdmin();
    }

    // ─── NOTIFICATIONS COLLECTION ───────────────────────
    // Users can only read their own notifications
    // System (admin) creates notifications

    match /notifications/{notificationId} {
      allow read: if isAuth() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow update: if isAuth() && 
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['isRead']);
      allow delete: if isAdmin();
    }

    // ─── DENY ALL OTHER COLLECTIONS ─────────────────────
    // Any collection not explicitly listed above is denied
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
