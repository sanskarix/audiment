rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    // Role helpers — purely from token claims (no Firestore lookups = no quota limits)
    function isAdmin() {
      return isAuth() && request.auth.token.role.lower() == 'admin';
    }

    function isManager() {
      return isAuth() && request.auth.token.role.lower() == 'manager';
    }

    function isAuditor() {
      return isAuth() && request.auth.token.role.lower() == 'auditor';
    }

    function isAdminOrManager() {
      return isAdmin() || isManager();
    }

    // Token-based org check — no Firestore lookup required
    function myOrgId() {
      return request.auth.token.organizationId;
    }


    // ─── ORGANIZATIONS COLLECTION ─────────────────────────────────────────────
    // Admin: full access to their own org document
    // Manager: read their own org document
    // Auditor: read their own org document

    match /organizations/{orgId} {
      allow read: if isAuth() && orgId == myOrgId();
      allow create: if isAdmin() && orgId == myOrgId();
      allow update: if isAdmin() && orgId == myOrgId();
      allow delete: if isAdmin() && orgId == myOrgId();

      // Nested settings subcollection
      match /settings/{settingDoc} {
        allow read: if isAuth() && orgId == myOrgId();
        allow write: if isAdmin() && orgId == myOrgId();
      }
    }


    // ─── USERS COLLECTION ────────────────────────────────────────────────────
    // Admin: full access
    // Manager: read any user in the system (to resolve names, auditors, etc.)
    // Auditor: read + update own document
    // Any user: update their own document (profile info, photo, etc.)

    match /users/{userId} {
      allow read: if isAuth() && (
        isAdmin() ||
        isManager() ||
        isAuditor() ||
        request.auth.uid == userId
      );
      allow create: if isAdmin();
      allow update: if isAdmin() || request.auth.uid == userId;
      allow delete: if isAdmin();
    }


    // ─── LOCATIONS COLLECTION ────────────────────────────────────────────────
    // Admin: full CRUD
    // Manager + Auditor: read all locations (filtered on client by org)

    match /locations/{locationId} {
      allow read: if isAuth() && (isAdmin() || isManager() || isAuditor());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }


    // ─── AUDIT TEMPLATES COLLECTION ──────────────────────────────────────────
    // Admin: full CRUD (including questions subcollection)
    // Manager + Auditor: read (to list templates; filtered by org on client)

    match /auditTemplates/{templateId} {
      allow read: if isAuth() && (isAdmin() || isManager() || isAuditor());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      match /questions/{questionId} {
        allow read: if isAuth() && (isAdmin() || isManager() || isAuditor());
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }


    // ─── AUDITS COLLECTION ───────────────────────────────────────────────────
    // Admin: full access
    // Manager: read all audits (filtered by org on client); create + update
    // Auditor: read own assigned audits; update own assigned audit (progress/submit)

    match /audits/{auditId} {
      allow read: if isAuth() && (
        isAdmin() ||
        isManager() ||
        (isAuditor() && resource.data.assignedAuditorId == request.auth.uid)
      );
      allow create: if isAdmin() || isManager();
      allow update: if isAdmin() || isManager() ||
        (isAuditor() && resource.data.assignedAuditorId == request.auth.uid);
      allow delete: if isAdmin();
    }


    // ─── AUDIT RESPONSES COLLECTION ──────────────────────────────────────────
    // Admin: full access
    // Manager: read all responses (to view reports)
    // Auditor: create + read + update own responses

    match /auditResponses/{responseId} {
      allow read: if isAuth() && (
        isAdmin() ||
        isManager() ||
        (isAuditor() && resource.data.auditorId == request.auth.uid)
      );
      allow create: if isAuth() && (
        isAdmin() ||
        isManager() ||
        (isAuditor() && request.resource.data.auditorId == request.auth.uid)
      );
      allow update: if isAdmin() || isManager() ||
        (isAuditor() && resource.data.auditorId == request.auth.uid);
      allow delete: if isAdmin();
    }


    // ─── CORRECTIVE ACTIONS COLLECTION ───────────────────────────────────────
    // Admin: full access
    // Manager: read + create + update (managing actions from their branches)
    // Auditor: create (auto-generated from audit submission batch)

    match /correctiveActions/{actionId} {
      allow read: if isAuth() && (isAdmin() || isManager() || isAuditor());
      allow create: if isAuth() && (isAdmin() || isManager() || isAuditor());
      allow update: if isAdmin() || isManager();
      allow delete: if isAdmin();
    }


    // ─── FLASHMOB AUDITS COLLECTION ──────────────────────────────────────────
    // CRITICAL: Managers must NEVER see flashmob data
    // Admin: full access
    // Auditor: create (blind submit) + read OWN submitted records (for history page)

    match /flashmobAudits/{flashmobId} {
      allow read: if isAdmin() ||
        (isAuditor() && resource.data.auditorId == request.auth.uid);
      allow create: if isAuditor() &&
        request.resource.data.auditorId == request.auth.uid &&
        request.resource.data.isVisibleToManager == false;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }


    // ─── NOTIFICATIONS COLLECTION ────────────────────────────────────────────
    // Admin: full access
    // Any authenticated user: create notifications (for system events, batch ops)
    // Users: read their own notifications
    // Users: update ONLY the isRead field on their own notifications
    // Users: delete their own notifications

    match /notifications/{notificationId} {
      allow read: if isAuth() && (
        isAdmin() ||
        isManager() ||
        isAuditor() ||
        resource.data.recipientId == request.auth.uid
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        isAdmin() ||
        (resource.data.recipientId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']))
      );
      allow delete: if isAdmin() ||
        (isAuth() && resource.data.recipientId == request.auth.uid);
    }


    // ─── DENY ALL OTHER COLLECTIONS ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
